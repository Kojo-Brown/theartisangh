# ─────────────────────────────────────────────────────────────
# The Artisan GH — environment configuration
# Copy to `.env` and fill values. Never commit the populated .env.
# ─────────────────────────────────────────────────────────────

NODE_ENV=development

# ── API ──
API_PORT=3000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:3000

# ── Web ──
WEB_PORT=4200
WEB_API_URL=http://localhost:3000

# ── Admin ──
ADMIN_PORT=4300

# ── Worker ──
WORKER_CONCURRENCY=4

# ── PostgreSQL ──
POSTGRES_USER=artisan
POSTGRES_PASSWORD=artisan
POSTGRES_DB=artisan
DATABASE_URL=postgresql://artisan:artisan@localhost:55432/artisan?schema=public

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Object storage (MinIO locally, Cloudflare R2 in prod) ──
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY=artisan
S3_SECRET_KEY=artisan_dev_secret
S3_BUCKET_MEDIA=artisangh-media
S3_BUCKET_KYC=artisangh-kyc
S3_FORCE_PATH_STYLE=true

# ── Auth ──
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── Hubtel (payments + SMS OTP) ──
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_MERCHANT_ACCOUNT=
HUBTEL_SMS_SENDER_ID=ArtisanGH
HUBTEL_PAYMENT_CALLBACK_URL=http://localhost:3000/payments/webhook

# ── Mapbox ──
MAPBOX_ACCESS_TOKEN=
MAPBOX_DIRECTIONS_PROFILE=driving-traffic

# ── Whisper (voice → text) ──
WHISPER_PROVIDER=openai           # openai | local
OPENAI_API_KEY=
WHISPER_MODEL=large-v3

# ── KYC / Ghana Card verification ──
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
KYC_KMS_KEY_ID=

# ── Observability ──
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# ── Mail (dev: MailHog) ──
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@theartisan.gh
