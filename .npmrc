# Hoist workspace packages to the root node_modules.
# Without this, Vite's SSR runner (chunks live in .angular/vite-root/) can't
# resolve `@artisangh/*` bare specifiers — Node walks up from the chunk
# location to node_modules/, and pnpm's deduped path
# (node_modules/.pnpm/node_modules/@artisangh/) is not on Node's search list.
public-hoist-pattern[]=@artisangh/*
