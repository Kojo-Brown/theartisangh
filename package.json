{
  "name": "@artisangh/source",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "description": "The Artisan GH — marketplace connecting Ghanaian customers with artisans, electricians, plumbers and skilled workers.",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev:api": "nx serve api",
    "dev:web": "nx serve web",
    "dev:worker": "nx serve worker",
    "dev:admin": "nx serve admin --port=4300",
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "db:up": "docker compose -f infra/docker/compose.dev.yml up -d",
    "db:down": "docker compose -f infra/docker/compose.dev.yml down",
    "db:logs": "docker compose -f infra/docker/compose.dev.yml logs -f",
    "prisma:generate": "dotenv -e .env -- pnpm --filter @artisangh/db prisma generate",
    "prisma:migrate": "dotenv -e .env -- pnpm --filter @artisangh/db prisma migrate dev",
    "prisma:studio": "dotenv -e .env -- pnpm --filter @artisangh/db prisma studio",
    "admin:promote": "dotenv -e .env -- tsx tools/scripts/promote-admin.ts",
    "prepare": "husky",
    "postinstall": "node tools/scripts/postinstall.mjs"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.2.0",
    "@angular-devkit/schematics": "~21.2.0",
    "@angular/build": "~21.2.0",
    "@angular/cli": "~21.2.0",
    "@angular/compiler-cli": "~21.2.0",
    "@angular/language-service": "~21.2.0",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/angular": "22.7.0",
    "@nx/devkit": "22.7.0",
    "@nx/eslint": "22.7.0",
    "@nx/eslint-plugin": "22.7.0",
    "@nx/jest": "22.7.0",
    "@nx/js": "22.7.0",
    "@nx/nest": "22.7.0",
    "@nx/node": "22.7.0",
    "@nx/playwright": "22.7.0",
    "@nx/vite": "22.7.0",
    "@nx/vitest": "22.7.0",
    "@nx/web": "22.7.0",
    "@nx/webpack": "22.7.0",
    "@oxc-project/runtime": "^0.115.0",
    "@playwright/test": "^1.36.0",
